{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Store inventory items",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "images": { "type": "array" },
        "stock": { "type": "number" },
        "rating": { "type": "number" },
        "reviews": { "type": "number" },
        "features": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "category", "images"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer purchase transaction",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string" },
        "shippingAddress": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "total", "status"]
    },
    "Review": {
      "title": "Review",
      "description": "Product review and rating",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Wishlist": {
      "title": "Wishlist",
      "description": "User's saved products",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "productIds": { "type": "array" }
      }
    }
  },
  "firestore": {
    "products": {
      "schema": "Product",
      "description": "Catalog of all products"
    },
    "orders": {
      "schema": "Order",
      "description": "Customer transactions"
    },
    "reviews": {
      "schema": "Review",
      "description": "Product reviews"
    },
    "wishlists": {
      "schema": "Wishlist",
      "description": "User wishlist data"
    },
    "users": {
        "schema": {
            "type": "object",
            "properties": {
                "email": { "type": "string" },
                "role": { "type": "string" },
                "createdAt": { "type": "string" }
            }
        },
        "description": "User profile data"
    }
  }
}
